{
  "api_config": {
    "endpoint": "https://api.example.com/v1",
    "timeout": 30,
    "retry_count": 3
  },
  "model_parameters": {
    "max_tokens": 512,
    "temperature": 0.7,
    "top_p": 0.9,
    "frequency_penalty": 0.1
  },
  "retrieval": {
    "use_hybrid_search": true,
    "rerank_results": true,
    "context_window": 1000
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "output_file": "rag_system.log"
  }
}
